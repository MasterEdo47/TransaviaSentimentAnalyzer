   "source": [
    "\"\"\"\n",
    "Transavia YouTube Comments Sentiment Analysis\n",
    "----------------------------------------------\n",
    "Scrapes comments from YouTube videos mentioning Transavia\n",
    "and performs sentiment analysis using VADER.\n",
    "\n",
    "Requirements:\n",
    "    pip install google-api-python-client vaderSentiment pandas matplotlib seaborn\n",
    "\n",
    "Setup:\n",
    "    1. Go to https://console.cloud.google.com/\n",
    "    2. Create a project → Enable \"YouTube Data API v3\"\n",
    "    3. Create an API key (free, 10,000 units/day quota)\n",
    "    4. Paste it below — no billing required for basic usage\n",
    "\"\"\"\n",
    "\n",
    "from googleapiclient.discovery import build\n",
    "from vaderSentiment.vaderSentiment import SentimentIntensityAnalyzer\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "from datetime import datetime\n",
    "\n",
    "# ─────────────────────────────────────────────\n",
    "# 1. YOUR API KEY — fill this in\n",
    "# ─────────────────────────────────────────────\n",
    "YOUTUBE_API_KEY = "Add your API Key Here",
    "\n",
    "# ─────────────────────────────────────────────\n",
    "# 2. CONNECT TO YOUTUBE\n",
    "# ─────────────────────────────────────────────\n",
    "youtube = build(\"youtube\", \"v3\", developerKey=YOUTUBE_API_KEY)\n",
    "\n",
    "# ─────────────────────────────────────────────\n",
    "# 3. SEARCH FOR TRANSAVIA VIDEOS\n",
    "# ─────────────────────────────────────────────\n",
    "def search_videos(query=\"Transavia\", max_results=10):\n",
    "    \"\"\"Search YouTube for videos mentioning Transavia.\"\"\"\n",
    "    print(f\"Searching YouTube for: '{query}' ...\")\n",
    "\n",
    "    response = youtube.search().list(\n",
    "        q=query,\n",
    "        part=\"snippet\",\n",
    "        maxResults=max_results,\n",
    "        type=\"video\",\n",
    "        relevanceLanguage=\"en\"\n",
    "    ).execute()\n",
    "\n",
    "    videos = []\n",
    "    for item in response[\"items\"]:\n",
    "        videos.append({\n",
    "            \"video_id\":    item[\"id\"][\"videoId\"],\n",
    "            \"title\":       item[\"snippet\"][\"title\"],\n",
    "            \"channel\":     item[\"snippet\"][\"channelTitle\"],\n",
    "            \"published\":   item[\"snippet\"][\"publishedAt\"][:10],\n",
    "            \"description\": item[\"snippet\"][\"description\"]\n",
    "        })\n",
    "\n",
    "    print(f\"  → {len(videos)} videos found.\")\n",
    "    return videos\n",
    "\n",
    "# ─────────────────────────────────────────────\n",
    "# 4. SCRAPE COMMENTS FROM EACH VIDEO\n",
    "# ─────────────────────────────────────────────\n",
    "def scrape_comments(video_id, max_comments=100):\n",
    "    \"\"\"Scrape top-level comments from a YouTube video.\"\"\"\n",
    "    comments = []\n",
    "    try:\n",
    "        request = youtube.commentThreads().list(\n",
    "            part=\"snippet\",\n",
    "            videoId=video_id,\n",
    "            maxResults=min(max_comments, 100),\n",
    "            textFormat=\"plainText\",\n",
    "            order=\"relevance\"\n",
    "        )\n",
    "        response = request.execute()\n",
    "\n",
    "        for item in response.get(\"items\", []):\n",
    "            c = item[\"snippet\"][\"topLevelComment\"][\"snippet\"]\n",
    "            comments.append({\n",
    "                \"video_id\":   video_id,\n",
    "                \"comment\":    c[\"textDisplay\"],\n",
    "                \"likes\":      c[\"likeCount\"],\n",
    "                \"date\":       c[\"publishedAt\"][:10]\n",
    "            })\n",
    "    except Exception as e:\n",
    "        print(f\"  ⚠ Could not fetch comments for video {video_id}: {e}\")\n",
    "\n",
    "    return comments\n",
    "\n",
    "# ─────────────────────────────────────────────\n",
    "# 5. SENTIMENT ANALYSIS WITH VADER\n",
    "# ─────────────────────────────────────────────\n",
    "def analyze_sentiment(df):\n",
    "    \"\"\"Apply VADER sentiment scoring to each comment.\"\"\"\n",
    "    analyzer = SentimentIntensityAnalyzer()\n",
    "\n",
    "    def get_sentiment(text):\n",
    "        scores   = analyzer.polarity_scores(text)\n",
    "        compound = scores[\"compound\"]\n",
    "        if compound >= 0.05:\n",
    "            label = \"Positive\"\n",
    "        elif compound <= -0.05:\n",
    "            label = \"Negative\"\n",
    "        else:\n",
    "            label = \"Neutral\"\n",
    "        return pd.Series({\n",
    "            \"compound\":  compound,\n",
    "            \"positive\":  scores[\"pos\"],\n",
    "            \"neutral\":   scores[\"neu\"],\n",
    "            \"negative\":  scores[\"neg\"],\n",
    "            \"sentiment\": label\n",
    "        })\n",
    "\n",
    "    print(\"Running sentiment analysis ...\")\n",
    "    df[[\"compound\", \"positive\", \"neutral\", \"negative\", \"sentiment\"]] = df[\"comment\"].apply(get_sentiment)\n",
    "    return df\n",
    "\n",
    "# ─────────────────────────────────────────────\n",
    "# 6. SUMMARY STATISTICS\n",
    "# ─────────────────────────────────────────────\n",
    "def print_summary(df, videos):\n",
    "    print(\"\\n─── Overall Sentiment Distribution ───\")\n",
    "    counts = df[\"sentiment\"].value_counts()\n",
    "    pcts   = df[\"sentiment\"].value_counts(normalize=True) * 100\n",
    "    summary = pd.DataFrame({\"Count\": counts, \"Percent (%)\": pcts.round(1)})\n",
    "    print(summary.to_string())\n",
    "\n",
    "    print(f\"\\n─── Average Compound Score: {df['compound'].mean():.3f} ───\")\n",
    "    print(\"  (Range: -1 = most negative, +1 = most positive)\\n\")\n",
    "\n",
    "    print(\"─── Top 3 Most Positive Comments ───\")\n",
    "    for _, row in df.nlargest(3, \"compound\")[[\"comment\", \"compound\"]].iterrows():\n",
    "        print(f\"  [{row['compound']:.2f}] {row['comment'][:100]}\")\n",
    "\n",
    "    print(\"\\n─── Top 3 Most Negative Comments ───\")\n",
    "    for _, row in df.nsmallest(3, \"compound\")[[\"comment\", \"compound\"]].iterrows():\n",
    "        print(f\"  [{row['compound']:.2f}] {row['comment'][:100]}\")\n",
    "\n",
    "# ─────────────────────────────────────────────\n",
    "# 7. VISUALIZATIONS\n",
    "# ─────────────────────────────────────────────\n",
    "def plot_results(df, videos):\n",
    "    fig, ax = plt.subplots(figsize=(6, 5))\n",
    "    fig.suptitle(\"Transavia — YouTube Comments Sentiment Analysis\",\n",
    "                 fontsize=13, fontweight=\"bold\")\n",
    "\n",
    "    colors = {\"Positive\": \"#2ecc71\", \"Neutral\": \"#95a5a6\", \"Negative\": \"#e74c3c\"}\n",
    "\n",
    "    counts = df[\"sentiment\"].value_counts().reindex([\"Positive\", \"Neutral\", \"Negative\"])\n",
    "    ax.bar(counts.index, counts.values,\n",
    "           color=[colors[s] for s in counts.index], edgecolor=\"white\", width=0.5)\n",
    "    ax.set_title(\"Sentiment Distribution\")\n",
    "    ax.set_ylabel(\"Number of Comments\")\n",
    "    for i, v in enumerate(counts.values):\n",
    "        ax.text(i, v + 1, str(v), ha=\"center\", fontweight=\"bold\")\n",
    "\n",
    "    plt.tight_layout()\n",
    "    plt.savefig(\"transavia_youtube_sentiment.png\", dpi=150, bbox_inches=\"tight\")\n",
    "    print(\"Plot saved as transavia_youtube_sentiment.png\")\n",
    "    plt.show()\n",
    "\n",
    "# ─────────────────────────────────────────────\n",
    "# 8. MAIN\n",
    "# ─────────────────────────────────────────────\n",
    "if __name__ == \"__main__\":\n",
    "    # Search for videos\n",
    "    videos = search_videos(query=\"Transavia\", max_results=10)\n",
    "\n",
    "    # Scrape comments from each video\n",
    "    all_comments = []\n",
    "    for video in videos:\n",
    "        print(f\"  Fetching comments: {video['title'][:60]}...\")\n",
    "        comments = scrape_comments(video[\"video_id\"], max_comments=100)\n",
    "        all_comments.extend(comments)\n",
    "\n",
    "    print(f\"\\nTotal comments collected: {len(all_comments)}\")\n",
    "\n",
    "    # Build DataFrame and run sentiment analysis\n",
    "    df = pd.DataFrame(all_comments)\n",
    "    df = analyze_sentiment(df)\n",
    "\n",
    "    # Results\n",
    "    print_summary(df, videos)\n",
    "    plot_results(df, videos)\n",
    "\n",
    "    # Save to CSV\n",
    "    df.to_csv(\"transavia_youtube_sentiment.csv\", index=False)\n",
    "    print(\"Results saved to transavia_youtube_sentiment.csv\")"
   ]
  },
